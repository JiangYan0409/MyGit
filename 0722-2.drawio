        <mxCell id="Iael_UGuqMmBIXJ2PFKk-28" parent="Iael_UGuqMmBIXJ2PFKk-67" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;strokeWidth=1;fontSize=11;fontFamily=Microsoft YaHei;align=left;spacingLeft=8;verticalAlign=top;spacingTop=5;" value="&lt;b&gt;线索十一（日）：意象投射&lt;/b&gt;&lt;br&gt;现象：日光炽烈、圆满恒定&lt;br&gt;应用：太阳文学🟣 太阳神话🟣" vertex="1">
          <mxGeometry height="65" width="350" x="35" y="410" as="geometry" />
        </mxCell>
        <mxCell id="Iael_UGuqMmBIXJ2PFKk-29" parent="Iael_UGuqMmBIXJ2PFKk-67" style="ellipse;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;fontSize=11;fontFamily=Microsoft YaHei;verticalAlign=middle;align=center;" value="&lt;b&gt;日月的意象融合&lt;/b&gt;" vertex="1">
