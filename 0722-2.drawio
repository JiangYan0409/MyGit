        <mxCell id="Iael_UGuqMmBIXJ2PFKk-17" parent="Iael_UGuqMmBIXJ2PFKk-65" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontFamily=Microsoft YaHei;align=left;spacingLeft=8;" value="米兰科维奇循环：太阳引力主导 + 巨行星摄动 + 月球调制岁差 → 冰期-间冰期交替 + 演化节拍" vertex="1">
          <mxGeometry height="28" width="280" x="335" y="153" as="geometry" />
        </mxCell>
        <mxCell id="Iael_UGuqMmBIXJ2PFKk-18" parent="Iael_UGuqMmBIXJ2PFKk-65" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontFamily=Microsoft YaHei;align=left;spacingLeft=8;" value="大小潮：日月引潮力叠加/抵消 → 海洋栖息多样性 + 繁殖同步信号" vertex="1">
          <mxGeometry height="28" width="300" x="635" y="153" as="geometry" />
        </mxCell>
        <mxCell id="Iael_UGuqMmBIXJ2PFKk-62" parent="Iael_UGuqMmBIXJ2PFKk-65" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=1;labelBackgroundColor=light-dark(#a0f3f1, #ededed);labelBorderColor=none;arcSize=50;" value="&lt;span style=&quot;color: rgb(15, 17, 21); font-family: quote-cjk-patch, Inter, system-ui, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, Roboto, Oxygen, Ubuntu, Cantarell, &amp;quot;Open Sans&amp;quot;, &amp;quot;Helvetica Neue&amp;quot;, sans-serif; text-align: start;&quot;&gt;&lt;font style=&quot;font-size: 8px;&quot;&gt;日月通过引力与辐射，为地球创造了一个宜居平台。太阳以引力固定轨道，以辐射驱动气候与生命，并催生臭氧层保护陆地。月球稳定地轴使气候长期温和，引发潮汐塑造海岸环境并可能参与生命起源，同时减缓自转至适宜节律。日月协同在万年尺度调控冰期轮回，在半月尺度调制潮汐节律&lt;/font&gt;&lt;/span&gt;" vertex="1">
          <mxGeometry height="30" width="1290" y="201" as="geometry" />
        </mxCell>
        <mxCell id="Iael_UGuqMmBIXJ2PFKk-67" connectable="0" parent="Iael_UGuqMmBIXJ2PFKk-77" style="group" value="" vertex="1">
          <mxGeometry height="780" width="1280" x="59" y="364" as="geometry" />
        </mxCell>
        <mxCell id="Iael_UGuqMmBIXJ2PFKk-21" parent="Iael_UGuqMmBIXJ2PFKk-67" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;strokeWidth=2;dashed=1;fontSize=13;fontFamily=Microsoft YaHei;verticalAlign=top;align=center;spacingTop=10;" value="&lt;b&gt;主体：日月影响体系&lt;/b&gt;&lt;br&gt;（古代气论视角 · 认知递进 · 观测→规律→法则→应用）" vertex="1">
          <mxGeometry height="620" width="1280" as="geometry" />
        </mxCell>
        <mxCell id="Iael_UGuqMmBIXJ2PFKk-22" parent="Iael_UGuqMmBIXJ2PFKk-67" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffdf0;strokeColor=#d6b656;strokeWidth=1;dashed=1;" value="" vertex="1">
          <mxGeometry height="565" width="380" x="20" y="35" as="geometry" />
        </mxCell>
        <mxCell id="Iael_UGuqMmBIXJ2PFKk-23" parent="Iael_UGuqMmBIXJ2PFKk-67" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontColor=#d6b656;fontFamily=Microsoft YaHei;" value="&lt;b&gt;太阳的影响（阳气之精）&lt;/b&gt;" vertex="1">
          <mxGeometry height="20" width="260" x="80" y="40" as="geometry" />
        </mxCell>
        <mxCell id="Iael_UGuqMmBIXJ2PFKk-24" parent="Iael_UGuqMmBIXJ2PFKk-67" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;strokeWidth=1;fontSize=11;fontFamily=Microsoft YaHei;align=left;spacingLeft=8;verticalAlign=top;spacingTop=5;" value="&lt;b&gt;线索一：四时法则&lt;/b&gt;&lt;br&gt;现象：日影年变化、寒暑交替&lt;br&gt;规律：回归年、二十四节气&lt;br&gt;应用：农业🟠 养生🟠 导航🩵" vertex="1">
          <mxGeometry height="70" width="350" x="35" y="70" as="geometry" />
        </mxCell>
        <mxCell id="Iael_UGuqMmBIXJ2PFKk-25" parent="Iael_UGuqMmBIXJ2PFKk-67" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;strokeWidth=1;fontSize=11;fontFamily=Microsoft YaHei;align=left;spacingLeft=8;verticalAlign=top;spacingTop=5;" value="&lt;b&gt;线索二：阳气昼夜法则&lt;/b&gt;&lt;br&gt;现象：昼夜更替&lt;br&gt;规律：日周期、平太阳时&lt;br&gt;应用：子午觉🟠 子午流注🟠" vertex="1">
          <mxGeometry height="70" width="350" x="35" y="155" as="geometry" />
        </mxCell>
        <mxCell id="Iael_UGuqMmBIXJ2PFKk-26" parent="Iael_UGuqMmBIXJ2PFKk-67" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;strokeWidth=1;fontSize=11;fontFamily=Microsoft YaHei;align=left;spacingLeft=8;verticalAlign=top;spacingTop=5;" value="&lt;b&gt;线索三：地气升降法则&lt;/b&gt;&lt;br&gt;现象：大地解冻封冻&lt;br&gt;规律：地温年变化&lt;br&gt;应用：坐北朝南🩵&amp;nbsp;风水🩵 神圣对位🩵" vertex="1">
          <mxGeometry height="70" width="350" x="35" y="240" as="geometry" />
        </mxCell>
        <mxCell id="Iael_UGuqMmBIXJ2PFKk-27" parent="Iael_UGuqMmBIXJ2PFKk-67" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;strokeWidth=1;fontSize=11;fontFamily=Microsoft YaHei;align=left;spacingLeft=8;verticalAlign=top;spacingTop=5;" value="&lt;b&gt;线索四：气之正戾法则&lt;/b&gt;&lt;br&gt;现象：日食、黑子&lt;br&gt;规律：交点月、沙罗周期&lt;br&gt;应用：灾异谏政🔴" vertex="1">
          <mxGeometry height="70" width="350" x="35" y="325" as="geometry" />
